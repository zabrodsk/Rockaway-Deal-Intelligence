# LLM Provider Configuration
# Supported: gemini, openai, anthropic, openrouter
LLM_PROVIDER=gemini
MODEL_NAME=gemini-3.1-flash-lite-preview

# Runtime environment
# Supported: development, staging, production
APP_ENV=development

# Google Gemini (required when LLM_PROVIDER=gemini)
GOOGLE_API_KEY=your_google_api_key_here

# Anthropic (required when LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI (required when LLM_PROVIDER=openai)
# OPENAI_API_KEY=your_openai_api_key_here
# Suggested MODEL_NAME values for LLM_PROVIDER=openai:
# gpt-5-nano | gpt-5-mini | gpt-5 | gpt-4.1-mini

# OpenRouter (required when LLM_PROVIDER=openrouter)
# OPENROUTER_API_KEY=your_openrouter_api_key_here
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Suggested MODEL_NAME values for LLM_PROVIDER=openrouter:
# openrouter/hunter-alpha
# OPENROUTER_SITE_URL=https://your-app.example.com
# OPENROUTER_APP_NAME=Deal Intelligence

# Web App Configuration
APP_PASSWORD=change-me-local-password
SESSION_SECRET=change-me-local-session-secret
# Private bearer auth for the agent-facing API facade (`/api/agent/*`)
# AGENT_API_ENABLED=true
# AGENT_API_KEY=change-me-agent-api-key
# Railway sets SERVICE_ROLE per service. Leave unset locally.
# SERVICE_ROLE=web
# Optional runtime version tags persisted with jobs
# APP_VERSION=development
# PROMPT_VERSION=v1
# PIPELINE_VERSION=v1
# SCHEMA_VERSION=20260306000000
# Dedicated Specter worker / Railway toggles
# ENABLE_SPECTER_WORKER_SERVICE=false
# SPECTER_WORKER_POLL_SECONDS=5
# RESTART_ON_IDLE_AFTER_ANALYSIS=false
# RESTART_ON_IDLE_DELAY_SECONDS=15
# Optional: override default session file path (default is $TMPDIR/startup_ranker_sessions.json)
# SESSION_STORE_PATH=/var/lib/startup-ranker/sessions.json
# Optional: override completed jobs persistence path (default is $TMPDIR/startup_ranker_jobs.json)
# JOBS_STORE_PATH=/var/lib/startup-ranker/jobs.json
# In production, APP_PASSWORD and SESSION_SECRET must not use placeholder values.

# LangSmith Configuration (optional, for tracing)
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=agent-experiment

# Web Search (optional — enables the web search toggle in the UI)
# Supported providers: sonar (Perplexity), brave (Brave Search)
WEB_SEARCH_PROVIDER=sonar
PPLX_API_KEY=your_perplexity_api_key_here
# BRAVE_SEARCH_API_KEY=your_brave_api_key_here

# Web search cost controls (when use_web_search=True)
# WEB_SEARCH_TRIGGER: "answer" = search only when LLM says it lacks evidence (default)
#                    "no_chunks" = legacy: search only when docs have zero chunks
# MAX_PPLX_CALLS_PER_COMPANY=100
# WEB_SEARCH_TRIGGER=answer

# Supabase (optional locally, required for production web/worker deployments)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
# Optional: shared storage bucket for uploaded source files
# SUPABASE_SOURCE_FILES_BUCKET=analysis-inputs

# Specter MCP (optional — enables URL-list intake and pitch-deck augmentation)
# Run scripts/specter_oauth_login.py once to mint CLIENT_ID + REFRESH_TOKEN.
# Rotated refresh tokens persist to the mcp_secrets Supabase table on each
# refresh, so the value here is only the BOOTSTRAP token; subsequent rotations
# are read from Supabase.
# SPECTER_MCP_URL=https://mcp.tryspecter.com/mcp
# SPECTER_MCP_CLIENT_ID=your_specter_mcp_client_id
# SPECTER_MCP_REFRESH_TOKEN=your_specter_mcp_refresh_token
